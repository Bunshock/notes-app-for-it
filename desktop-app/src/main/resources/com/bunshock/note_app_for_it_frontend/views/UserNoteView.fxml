<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.controlsfx.control.SearchableComboBox?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bunshock.note_app_for_it_frontend.controllers.UserNoteController">
    <children>

        <!-- User Note Type Selection -->
        <VBox spacing="0" style="-fx-padding: 0 0 5 0;">
            <children>
                <Label text="TIPO DE MOVIMIENTO" styleClass="form-section-caption"/>
                <HBox prefHeight="40.0" spacing="0">
                    <fx:define>
                        <ToggleGroup fx:id="typeGroup" />
                    </fx:define>
                    <children>
                        <ToggleButton fx:id="btnTypeEntrega" text="ENTREGA" selected="true"
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="type-button-left" toggleGroup="$typeGroup"/>
                        <ToggleButton fx:id="btnTypeDevolucion" text="DEVOLUCIÓN" 
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="type-button-middle" toggleGroup="$typeGroup"/>
                        <ToggleButton fx:id="btnTypePrestamo" text="PRÉSTAMO" 
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="type-button-middle" toggleGroup="$typeGroup"/>
                        <ToggleButton fx:id="btnTypeFinContrato" text="FIN DE CONTRATO (ENTREGA)" 
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="type-button-right" toggleGroup="$typeGroup"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <Separator style="-fx-opacity: 0.5;"/>

        <!-- User details -->
        <VBox spacing="10">
           <children>
               <Label text="DATOS DEL USUARIO" style="-fx-font-weight: bold; -fx-text-fill: #0c8570; -fx-font-size: 13px;"/>
               <GridPane hgap="15" vgap="5">
                   <columnConstraints>
                       <ColumnConstraints percentWidth="25"/>
                       <ColumnConstraints percentWidth="40"/>
                       <ColumnConstraints percentWidth="35"/>
                   </columnConstraints>
                   <children>
                       <VBox spacing="2" GridPane.columnIndex="0">
                           <Label text="DNI" styleClass="input-label-small"/>
                           <TextField fx:id="txtUserDni" promptText="DNI" styleClass="form-input-main"/>
                       </VBox>
                       <VBox spacing="2" GridPane.columnIndex="1">
                           <Label text="NOMBRE COMPLETO" styleClass="input-label-small"/>
                           <TextField fx:id="txtUserName" editable="false" styleClass="form-input-disabled"/>
                       </VBox>
                       <VBox spacing="2" GridPane.columnIndex="2">
                           <Label text="EMAIL" styleClass="input-label-small"/>
                           <TextField fx:id="txtUserEmail" editable="false" styleClass="form-input-disabled"/>
                       </VBox>
                   </children>
               </GridPane>
           </children>
       </VBox>

       <Separator style="-fx-opacity: 0.5;"/>

        <!-- Equipment detail tables -->
       <VBox spacing="15" VBox.vgrow="ALWAYS">
            <children>
                <Label text="DETALLE DEL EQUIPAMIENTO" style="-fx-font-weight: bold; -fx-text-fill: #0c8570; -fx-font-size: 13px;"/>

                <!-- Equipment details - Asset -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="EQUIPOS CON S/N (Notebooks, Monitores, etc.)" styleClass="form-section-caption"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="+ Agregar" onAction="#handleAddItem" styleClass="add-button-small"/>
                        </HBox>
                        <TableView fx:id="tblAssets" styleClass="modern-table" prefHeight="200">
                            <columns>
                                <TableColumn fx:id="colAssetType" text="TIPO" prefWidth="100"/>
                                <TableColumn fx:id="colAssetBrand" text="MARCA" prefWidth="100"/>
                                <TableColumn fx:id="colAssetSerial" text="S/N" prefWidth="150"/>
                                <TableColumn fx:id="colAssetAF" text="A/F" prefWidth="80"/>
                                <TableColumn fx:id="colAssetActions" text="ACCIONES" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <!-- Equipment details - Countable -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="PERIFÉRICOS Y OTROS (Por Cantidad)" styleClass="form-section-caption"/>
                        <TableView fx:id="tblCountables" styleClass="modern-table" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="colCountType" text="TIPO" prefWidth="100"/>
                                <TableColumn fx:id="colCountBrand" text="MARCA" prefWidth="100"/>
                                <TableColumn fx:id="colCountQty" text="CANT." prefWidth="60"/>
                                <TableColumn fx:id="colCountObs" text="OBSERVACIONES" prefWidth="250"/>
                                <TableColumn fx:id="colCountActions" text="ACCIONES" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
        
    </children>
</VBox>