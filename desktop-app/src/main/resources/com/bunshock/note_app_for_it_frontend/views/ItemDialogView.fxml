<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.controlsfx.control.SearchableComboBox?>

<VBox spacing="20" prefWidth="450.0" style="-fx-padding: 25; -fx-background-color: white;" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.bunshock.note_app_for_it_frontend.controllers.ItemDialogController">
    
    <children>
        <Label text="DETALLES DEL ITEM" style="-fx-font-weight: bold; -fx-text-fill: #0c8570; -fx-font-size: 16px;"/>

        <HBox alignment="CENTER" prefHeight="40.0" spacing="0">
            <children>
                <ToggleButton fx:id="btnModeAsset" text="ÚNICO (S/N)" maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                              selected="true" onAction="#handleModeChange" styleClass="type-button-left">
                    <toggleGroup>
                        <ToggleGroup fx:id="modeGroup"/>
                    </toggleGroup>
                </ToggleButton>
                <ToggleButton fx:id="btnModeCountable" text="POR CANTIDAD" maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                              onAction="#handleModeChange" styleClass="type-button-right" toggleGroup="$modeGroup"/>
            </children>
        </HBox>

        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="35"/>
                <ColumnConstraints percentWidth="65"/>
            </columnConstraints>
            <children>
                <Label text="TIPO DE ITEM" styleClass="input-label-small" GridPane.rowIndex="0"/>
                <SearchableComboBox fx:id="cmbType" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="MARCA" styleClass="input-label-small" GridPane.rowIndex="1"/>
                <TextField fx:id="txtBrand" styleClass="form-input-main" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="MODELO" styleClass="input-label-small" GridPane.rowIndex="2"/>
                <TextField fx:id="txtModel" styleClass="form-input-main" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </children>
        </GridPane>

        <VBox fx:id="containerAssetFields" spacing="15">
            <children>
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35"/>
                        <ColumnConstraints percentWidth="65"/>
                    </columnConstraints>
                    <children>
                        <Label text="NÚMERO DE SERIE" styleClass="input-label-small" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtSerial" styleClass="form-input-main" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="ACTIVO FIJO (A/F)" styleClass="input-label-small" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtAF" styleClass="form-input-main" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </children>
                </GridPane>
            </children>
        </VBox>

        <VBox fx:id="containerCountableFields" spacing="15" visible="false" managed="false">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <Label text="CANTIDAD" styleClass="input-label-small" prefWidth="135"/>
                        <Spinner fx:id="spinQty" editable="true" prefWidth="100"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="5">
            <children>
                <Label text="COMENTARIOS / ESTADO" styleClass="input-label-small"/>
                <TextField fx:id="txtObs" styleClass="form-input-main" promptText="Opcional..."/>
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <children>
                <Button text="Cancelar" onAction="#onCancel" style="-fx-background-color: transparent; -fx-text-fill: #666;"/>
                <Button fx:id="btnAdd" text="Añadir a la Nota" onAction="#onSave" 
                        style="-fx-background-color: #0c8570; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
            </children>
        </HBox>
    </children>
</VBox>