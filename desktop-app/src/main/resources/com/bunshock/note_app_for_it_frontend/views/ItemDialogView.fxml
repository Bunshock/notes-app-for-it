<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.controlsfx.control.SearchableComboBox?>

<VBox spacing="20" style="-fx-padding: 25; -fx-background-color: white;" 
      prefWidth="450.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.bunshock.note_app_for_it_frontend.controllers.ItemDialogController">
    <children>
        <Label text="AGREGAR EQUIPAMIENTO" style="-fx-font-weight: bold; -fx-text-fill: #0c8570; -fx-font-size: 16px;"/>
        
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints prefWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <children>
                <Label text="Tipo de Item:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="input-label-small"/>
                <SearchableComboBox fx:id="cmbType" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                
                <Label text="Número de Serie:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="input-label-small"/>
                <TextField fx:id="txtSerial" promptText="S/N o Service Tag" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="modern-text-field-small"/>
                
                <Label text="Observaciones:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="input-label-small"/>
                <TextArea fx:id="txtObs" prefHeight="80" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="modern-text-field-small"/>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <children>
                <Button text="Cancelar" onAction="#onCancelClick" style="-fx-background-color: transparent; -fx-text-fill: #666;"/>
                <Button fx:id="btnAdd" text="Agregar a la Lista" onAction="#onAddClick" style="-fx-background-color: #0c8570; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>